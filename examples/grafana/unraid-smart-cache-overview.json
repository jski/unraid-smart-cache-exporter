{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_temperature_celsius{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Disk Temperature",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_snapshot_age_seconds{source_node=~\"$source_node\",disk=~\"$disk\"} / 60",
          "legendFormat": "{{disk}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "SMART Snapshot Age (minutes)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(max by (disk) ((unraid_smart_pending_sectors{source_node=~\"$source_node\"} > 0) or (unraid_smart_offline_uncorrectable{source_node=~\"$source_node\"} > 0) or (unraid_smart_reallocated_sectors{source_node=~\"$source_node\"} > 0)))",
          "legendFormat": "disks",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Disks With SMART Issues",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(unraid_smart_snapshot_age_seconds{source_node=~\"$source_node\"} > 86400)",
          "legendFormat": "stale",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Stale SMART Snapshots (>24h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_pending_sectors{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "pending {{disk}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_reallocated_sectors{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "reallocated {{disk}}",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_offline_uncorrectable{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "offline_uncorrectable {{disk}}",
          "range": true,
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_udma_crc_errors{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "udma_crc {{disk}}",
          "range": true,
          "refId": "D"
        }
      ],
      "title": "SMART Error Counters",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "clamp_min(rate(unraid_disk_reads_total{source_node=~\"$source_node\",disk=~\"$disk\"}[15m]), 0)",
          "legendFormat": "reads {{disk}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "clamp_min(rate(unraid_disk_writes_total{source_node=~\"$source_node\",disk=~\"$disk\"}[15m]), 0)",
          "legendFormat": "writes {{disk}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Disk IO Rate (from disks.ini counters)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_power_on_hours{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "power_on_hours {{disk}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_start_stop_count{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "start_stop {{disk}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Disk Lifecycle Counters",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "unraid",
    "smart",
    "disk-health"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "unraid",
          "value": "unraid"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(unraid_smart_cache_up, source_node)",
        "hide": 0,
        "includeAll": false,
        "label": "Source Node",
        "multi": false,
        "name": "source_node",
        "options": [],
        "query": {
          "query": "label_values(unraid_smart_cache_up, source_node)",
          "refId": "Prometheus-source_node"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(unraid_smart_temperature_celsius{source_node=~\"$source_node\"}, disk)",
        "hide": 0,
        "includeAll": true,
        "label": "Disk",
        "multi": true,
        "name": "disk",
        "options": [],
        "query": {
          "query": "label_values(unraid_smart_temperature_celsius{source_node=~\"$source_node\"}, disk)",
          "refId": "Prometheus-disk"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Unraid SMART Cache Exporter Overview",
  "uid": "unraid-smart-cache",
  "version": 1,
  "weekStart": ""
}
