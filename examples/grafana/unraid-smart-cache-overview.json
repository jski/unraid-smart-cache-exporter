{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_temperature_celsius{source_node=~\"$source_node\",disk=~\"$disk\"} and on (disk, source_node) (unraid_smart_snapshot_age_seconds{source_node=~\"$source_node\",disk=~\"$disk\"} < bool 21600)",
          "legendFormat": "{{disk}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Disk Temperature",
      "type": "timeseries",
      "description": "Tracks SMART temperature for disks with fresh snapshots (<6h). Missing lines indicate stale or unavailable SMART data, not necessarily cool disks."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Snapshot Age (minutes)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "m"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Freshness"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "fresh",
                        "color": "green"
                      },
                      "0": {
                        "text": "stale",
                        "color": "red"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_snapshot_age_seconds{source_node=~\"$source_node\",disk=~\"$disk\"} / 60",
          "legendFormat": "{{disk}}",
          "range": false,
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_snapshot_age_seconds{source_node=~\"$source_node\",disk=~\"$disk\"} < bool 21600",
          "legendFormat": "{{disk}}",
          "range": false,
          "refId": "B",
          "instant": true,
          "format": "table"
        }
      ],
      "title": "SMART Snapshot Freshness by Disk",
      "type": "table",
      "description": "Shows snapshot age and freshness (<6h) per disk. Stale means temperature/SMART counters may not reflect current disk state.",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "source_node": true
            }
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "disk": "Disk",
              "Value #A": "Snapshot Age (minutes)",
              "Value #B": "Freshness"
            }
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(max by (disk) ((unraid_smart_pending_sectors{source_node=~\"$source_node\"} > 0) or (unraid_smart_offline_uncorrectable{source_node=~\"$source_node\"} > 0) or (unraid_smart_reallocated_sectors{source_node=~\"$source_node\"} > 0)))",
          "legendFormat": "disks",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Disks With SMART Issues",
      "type": "stat",
      "description": "Counts disks with critical SMART sector signals (pending/offline-uncorrectable/reallocated). Any non-zero value is a health warning that should be triaged."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(unraid_smart_snapshot_age_seconds{source_node=~\"$source_node\"} > 86400)",
          "legendFormat": "stale",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Stale SMART Snapshots (>24h)",
      "type": "stat",
      "description": "Counts disks with SMART snapshots older than 24h. Stale snapshots reduce confidence in all SMART-based inferences and alerting."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_pending_sectors{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "pending {{disk}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_reallocated_sectors{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "reallocated {{disk}}",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_offline_uncorrectable{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "offline_uncorrectable {{disk}}",
          "range": true,
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_udma_crc_errors{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "udma_crc {{disk}}",
          "range": true,
          "refId": "D"
        }
      ],
      "title": "SMART Error Counters",
      "type": "timeseries",
      "description": "Raw SMART error counters by disk. Rising values over time are more important than one-time values and can indicate degrading media or link quality."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Power-On Hours"
            },
            "properties": [
              {
                "id": "unit",
                "value": "h"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Start/Stop Count"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Start/Stop Delta (24h)"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Power-On Delta (24h)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "h"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 7,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "source_node": true
            }
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "device": "Device",
              "disk": "Disk",
              "Value #A": "Power-On Hours",
              "Value #B": "Start/Stop Count",
              "Value #C": "Start/Stop Delta (24h)",
              "Value #D": "Power-On Delta (24h)"
            }
          }
        }
      ],
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_power_on_hours{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "power_on_hours {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_start_stop_count{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "start_stop {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "clamp_min(delta(unraid_smart_start_stop_count{source_node=~\"$source_node\",disk=~\"$disk\"}[24h]), 0)",
          "legendFormat": "start_stop_delta_24h {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "clamp_min(delta(unraid_smart_power_on_hours{source_node=~\"$source_node\",disk=~\"$disk\"}[24h]), 0)",
          "legendFormat": "power_on_hours_delta_24h {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "D"
        }
      ],
      "title": "Disk Lifecycle Counters (Current + 24h Delta)",
      "type": "table",
      "description": "Lifecycle counters from SMART (current values plus 24h delta). This panel hides query evaluation time so only disk lifecycle fields are shown."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "\\(24h\\)$"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 8,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "source_node": true
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "disk": "Disk",
              "Value #A": "Spinning Up (24h)",
              "Value #B": "Spinning Down (24h)",
              "Value #C": "Read SMART (24h)"
            }
          }
        }
      ],
      "targets": [
        {
          "editorMode": "code",
          "expr": "floor((sum by (disk) (changes(unraid_disk_last_event_timestamp_seconds{source_node=~\"$source_node\",disk=~\"$disk\",event=\"spinning up\"}[24h]))) or on(disk) (0 * max by (disk) (unraid_disk_spin_state{source_node=~\"$source_node\",disk=~\"$disk\"})))",
          "legendFormat": "spinning_up {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "floor((sum by (disk) (changes(unraid_disk_last_event_timestamp_seconds{source_node=~\"$source_node\",disk=~\"$disk\",event=\"spinning down\"}[24h]))) or on(disk) (0 * max by (disk) (unraid_disk_spin_state{source_node=~\"$source_node\",disk=~\"$disk\"})))",
          "legendFormat": "spinning_down {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "floor((sum by (disk) (changes(unraid_disk_last_event_timestamp_seconds{source_node=~\"$source_node\",disk=~\"$disk\",event=\"read SMART\"}[24h]))) or on(disk) (0 * max by (disk) (unraid_disk_spin_state{source_node=~\"$source_node\",disk=~\"$disk\"})))",
          "legendFormat": "read_smart {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "C"
        }
      ],
      "title": "Disk State Events (24h)",
      "type": "table",
      "description": "One compact row per disk showing lifecycle event updates in the last 24h."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Spin State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "-1": {
                        "color": "gray",
                        "text": "unknown"
                      },
                      "0": {
                        "color": "green",
                        "text": "down"
                      },
                      "1": {
                        "color": "orange",
                        "text": "up"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "Spin State Age|Hours Since .*"
            },
            "properties": [
              {
                "id": "unit",
                "value": "h"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "Last .* Time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 9,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max by (disk) (unraid_disk_spin_state{source_node=~\"$source_node\",disk=~\"$disk\"})",
          "legendFormat": "spin_state {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "max by (disk) ((unraid_disk_spin_state_age_seconds{source_node=~\"$source_node\",disk=~\"$disk\"}) / 3600)",
          "legendFormat": "spin_state_age_h {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "(time() - unraid_disk_last_spindown_timestamp_seconds{source_node=~\"$source_node\",disk=~\"$disk\"}) / 3600",
          "legendFormat": "hrs_since_spindown {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "(time() - unraid_disk_last_smart_read_timestamp_seconds{source_node=~\"$source_node\",disk=~\"$disk\"}) / 3600",
          "legendFormat": "hrs_since_smart_read {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "D"
        },
        {
          "editorMode": "code",
          "expr": "unraid_disk_last_spindown_timestamp_seconds{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "last_spindown_ts {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "E"
        },
        {
          "editorMode": "code",
          "expr": "unraid_disk_last_smart_read_timestamp_seconds{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "last_smart_read_ts {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "F"
        },
        {
          "editorMode": "code",
          "expr": "max by (disk) (unraid_disk_spin_state_last_change_timestamp_seconds{source_node=~\"$source_node\",disk=~\"$disk\"})",
          "legendFormat": "spin_state_last_change_ts {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "G"
        }
      ],
      "title": "Current Spin State + Event Age/Time",
      "type": "table",
      "description": "Current inferred spin state with both relative age and absolute event timestamps for easier validation of recent manual spin actions.",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "source_node": true
            }
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "disk": "Disk",
              "Value #A": "Spin State",
              "Value #B": "Spin State Age",
              "Value #C": "Hours Since Spindown",
              "Value #D": "Hours Since SMART Read",
              "Value #E": "Last Spindown Time",
              "Value #F": "Last SMART Read Time",
              "Value #G": "Last State Change Time"
            }
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 8
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 24
      },
      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
