        {
          "editorMode": "code",
          "expr": "(unraid_disk_spin_state_age_seconds{source_node=~\"$source_node\",disk=~\"$disk\"}) / 3600",
          "legendFormat": "spin_state_age_h {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "B"
