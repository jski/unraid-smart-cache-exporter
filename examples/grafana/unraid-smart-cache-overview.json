{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "logs",
      "name": "Logs",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_temperature_celsius{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Disk Temperature",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_snapshot_age_seconds{source_node=~\"$source_node\",disk=~\"$disk\"} / 60",
          "legendFormat": "{{disk}}",
          "range": false,
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "title": "SMART Snapshot Age (minutes) by Disk",
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(max by (disk) ((unraid_smart_pending_sectors{source_node=~\"$source_node\"} > 0) or (unraid_smart_offline_uncorrectable{source_node=~\"$source_node\"} > 0) or (unraid_smart_reallocated_sectors{source_node=~\"$source_node\"} > 0)))",
          "legendFormat": "disks",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Disks With SMART Issues",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(unraid_smart_snapshot_age_seconds{source_node=~\"$source_node\"} > 86400)",
          "legendFormat": "stale",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Stale SMART Snapshots (>24h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_pending_sectors{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "pending {{disk}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_reallocated_sectors{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "reallocated {{disk}}",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_offline_uncorrectable{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "offline_uncorrectable {{disk}}",
          "range": true,
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_udma_crc_errors{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "udma_crc {{disk}}",
          "range": true,
          "refId": "D"
        }
      ],
      "title": "SMART Error Counters",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 7,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "unraid_smart_power_on_hours{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "power_on_hours {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "unraid_smart_start_stop_count{source_node=~\"$source_node\",disk=~\"$disk\"}",
          "legendFormat": "start_stop {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "clamp_min(delta(unraid_smart_start_stop_count{source_node=~\"$source_node\",disk=~\"$disk\"}[24h]), 0)",
          "legendFormat": "start_stop_delta_24h {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "clamp_min(delta(unraid_smart_power_on_hours{source_node=~\"$source_node\",disk=~\"$disk\"}[24h]), 0)",
          "legendFormat": "power_on_hours_delta_24h {{disk}}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "D"
        }
      ],
      "title": "Disk Lifecycle Counters (Current + 24h Delta)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{job=\"system-logs\",host=~\"$source_node\"} |~ \"emhttpd: (spinning down|spinning up|read SMART) /dev/sd[a-z]\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Disk State Events (System Logs)",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "id": 9,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      },
      "targets": [
        {
          "expr": "sum by (device, event) (count_over_time({job=\"system-logs\",host=~\"$source_node\"} |~ \"emhttpd: (spinning down|spinning up|read SMART) /dev/sd[a-z]\" | regexp \"emhttpd: (?P<event>spinning down|spinning up|read SMART) /dev/(?P<device>sd[a-z])\" [24h]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Disk State Event Counts (24h)",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "unraid",
    "smart",
    "disk-health"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "unraid",
          "value": "unraid"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(unraid_smart_cache_up, source_node)",
        "hide": 0,
        "includeAll": false,
        "label": "Source Node",
        "multi": false,
        "name": "source_node",
        "options": [],
        "query": {
          "query": "label_values(unraid_smart_cache_up, source_node)",
          "refId": "Prometheus-source_node"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(unraid_smart_temperature_celsius{source_node=~\"$source_node\"}, disk)",
        "hide": 0,
        "includeAll": true,
        "label": "Disk",
        "multi": true,
        "name": "disk",
        "options": [],
        "query": {
          "query": "label_values(unraid_smart_temperature_celsius{source_node=~\"$source_node\"}, disk)",
          "refId": "Prometheus-disk"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Unraid SMART Cache Exporter Overview",
  "uid": "unraid-smart-cache",
  "version": 1,
  "weekStart": ""
}
